DATABASE_URL=sqlite:///./pam_lite.db
SECRET_KEY=change-me
JWT_EXPIRE_MINUTES=480
PAM_EXECUTOR_MODE=mock
PAM_EXECUTOR_SSH_KEY_PATH=/run/secrets/pam_ssh_key
SCHEDULER_INTERVAL_SECONDS=60
PAM_SESSION_LOG_IMPORT_ENABLED=true
PAM_SESSION_LOG_DIR=/var/log/pam-lite
PAM_DEFAULT_ADMIN_USER=administrator
PAM_DEFAULT_ADMIN_EMAIL=administrator@localhost.localdomain
PAM_DEFAULT_ADMIN_PASSWORD=admin123
PAM_ACCESS_MODE=direct
PAM_GROUP_SCOPED_ACCESS=false
PAM_GATEWAY_ENABLED=false
PAM_GATEWAY_HOST=0.0.0.0
PAM_GATEWAY_PORT=2222
PAM_GATEWAY_HOST_KEY_PATH=/data/gateway_host_key
PAM_GATEWAY_SESSION_RECORDING=false
PAM_GATEWAY_COMMAND_LOGGING=false
PAM_GATEWAY_IDLE_TIMEOUT_SECONDS=900
PAM_GATEWAY_MAX_SESSION_SECONDS=28800
PAM_VAULT_MODE=local_encrypted
PAM_VAULT_MASTER_KEY=change-this-32-byte-key
PAM_VAULT_EXTERNAL_URL=
PAM_VAULT_EXTERNAL_TOKEN=
PAM_SECRET_ROTATION_ENABLED=false
PAM_SECRET_ROTATION_INTERVAL_HOURS=24
PAM_SSH_KEY_ROTATION_ENABLED=false
PAM_SSH_KEY_TYPE=ed25519
PAM_SSH_KEY_BITS=4096
PAM_SECRET_ACCESS_AUDIT_ENABLED=true
PAM_POLICY_ENGINE_ENABLED=false
PAM_RISK_ENGINE_ENABLED=false
PAM_ALERTS_ENABLED=false
PAM_AUTO_REVOKE_ON_CRITICAL_RISK=false
PAM_REQUIRE_REASON_FOR_PROD=false
PAM_REQUIRE_APPROVAL_FOR_PROD=false
PAM_REQUIRE_SESSION_RECORDING_FOR_PROD=false
PAM_REQUIRE_MFA_FOR_PROD=false
PAM_MAX_RISK_SCORE=100
PAM_CRITICAL_RISK_SCORE=80
PAM_HIGH_RISK_SCORE=60
PAM_MEDIUM_RISK_SCORE=30
PAM_AUTH_PROVIDERS=local_os,local_db,ldap,oidc
PAM_DEFAULT_AUTH_PROVIDER=local_db
PAM_LOCAL_AUTH_MODE=database
PAM_OS_PAM_SERVICE=login
PAM_OS_ADMIN_USERS=root
PAM_OS_AUTO_PROVISION=false
PAM_MFA_ENABLED=false
PAM_MFA_ISSUER=Linux PAM Lite
PAM_MFA_REQUIRED_FOR_ADMIN=false
PAM_MFA_REQUIRED_FOR_PROD=false
PAM_MFA_REQUIRED_FOR_FULL_SUDO=false
PAM_MFA_REQUIRED_FOR_GATEWAY=false
PAM_MFA_REQUIRED_FOR_SECRET_ROTATION=false
PAM_MFA_TOKEN_TTL_SECONDS=300
PAM_STEP_UP_TTL_SECONDS=900
PAM_LDAP_ENABLED=false
PAM_LDAP_URL=ldap://ldap.example.local:389
PAM_LDAP_BIND_DN=
PAM_LDAP_BIND_PASSWORD=
PAM_LDAP_BASE_DN=dc=example,dc=local
PAM_LDAP_USER_FILTER=(sAMAccountName={username})
PAM_LDAP_GROUP_FILTER=(member={user_dn})
PAM_LDAP_USE_TLS=false
PAM_LDAP_ROLE_ADMIN_GROUP=Linux-PAM-Admins
PAM_LDAP_ROLE_APPROVER_GROUP=Linux-PAM-Approvers
PAM_LDAP_ROLE_USER_GROUP=Linux-PAM-Users
PAM_OIDC_ENABLED=false
PAM_OIDC_ISSUER_URL=
PAM_OIDC_CLIENT_ID=
PAM_OIDC_CLIENT_SECRET=
PAM_OIDC_REDIRECT_URI=http://localhost:8080/auth/oidc/callback
PAM_OIDC_ROLE_CLAIM=roles
PAM_OIDC_USERNAME_CLAIM=preferred_username
PAM_OIDC_EMAIL_CLAIM=email
PAM_OIDC_ADMIN_ROLE=pam_admin
PAM_OIDC_APPROVER_ROLE=pam_approver
PAM_OIDC_USER_ROLE=pam_user
PAM_REGISTRATION_REQUIRE_HTTPS=true
PAM_REGISTRATION_RATE_LIMIT_COUNT=10
PAM_REGISTRATION_RATE_LIMIT_WINDOW_MINUTES=60
PAM_REGISTRATION_KNOWN_HOSTS_PATH=/data/registration_known_hosts
# Multi-protocol browser worker. Keep both directories outside frontend/public.
PAM_ARTIFACT_DIR=/app/data/pam-artifacts
PAM_BROWSER_PROFILE_DIR=/tmp/algen-pam-browser-profiles
PAM_BROWSER_HEADLESS=true
PAM_BROWSER_CONCURRENCY=8
PAM_WEB_VIEWPORT_WIDTH=1440
PAM_WEB_VIEWPORT_HEIGHT=900
PAM_WEB_RECORD_SCREENSHOTS=false
PAM_WEB_IDLE_TIMEOUT_SECONDS=900
PAM_WEB_ABSOLUTE_TIMEOUT_SECONDS=28800
PAM_WEBSOCKET_TOKEN_TTL_SECONDS=60
PAM_VNC_ENABLED=false
PAM_CORS_ORIGINS=
