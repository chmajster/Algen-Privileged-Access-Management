DATABASE_URL=sqlite:////data/db/pam.db
SECRET_KEY=replace-with-at-least-32-random-bytes
JWT_EXPIRE_MINUTES=480
PAM_DEFAULT_ADMIN_USER=administrator
PAM_DEFAULT_ADMIN_EMAIL=administrator@example.com
PAM_DEFAULT_ADMIN_PASSWORD=replace-immediately
PAM_LOCAL_AUTH_MODE=database
PAM_AUTH_PROVIDERS=local_db,ldap,oidc
PAM_MFA_ENABLED=true
PAM_MFA_REQUIRED_FOR_ADMIN=true
PAM_VAULT_MODE=local_encrypted
PAM_VAULT_MASTER_KEY=replace-with-a-long-random-value
PAM_ARTIFACT_DIR=/data/artifacts
PAM_BROWSER_PROFILE_DIR=/data/browser-profiles
PAM_BROWSER_HEADLESS=true
PAM_BROWSER_CONCURRENCY=4
PAM_WEB_IDLE_TIMEOUT_SECONDS=900
PAM_WEB_ABSOLUTE_TIMEOUT_SECONDS=3600
PAM_WEB_STREAM_TOKEN_TTL_SECONDS=60
PAM_WEB_MAX_UPLOAD_BYTES=10485760
PAM_WEB_MAX_DOWNLOAD_BYTES=10485760
